# Compiled outputs — formatting source of truth is the .ts files, not the output
dist/

# Test coverage reports — generated by Vitest, not source code
coverage/

# Third-party code — never format node_modules
node_modules/

# GraphQL codegen output — generated files are machine-written; reformatting them
# produces noisy diffs and doesn't improve readability.
# The *.graphql files follow GraphQL style conventions (not JS/TS), and Prettier's
# GraphQL formatter can conflict with schema linting tools like graphql-inspector.
**/__generated__/
*.graphql

# Nx internal cache — not source, no value in formatting
.nx/