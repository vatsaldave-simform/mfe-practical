{
  "name": "@mfe-practical/cart",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cart/src",
  "projectType": "application",
  "tags": ["scope:app", "type:feature"],
  "// targets": "to see all targets run: nx show project @mfe-practical/cart --web",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cart",
        "command": "rspack serve --node-env=development --port=4202"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/cart/vitest.config.ts --passWithNoTests"
      }
    }
  }
}
